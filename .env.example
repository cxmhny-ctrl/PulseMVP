# === Local development (SQLite) ===
DATABASE_URL="file:./dev.db"

# === Production (Postgres — Neon / Supabase / Vercel Postgres) ===
# 1. Change `provider = "sqlite"` to `provider = "postgresql"` in prisma/schema.prisma
# 2. Set DATABASE_URL to your Postgres connection string:
# DATABASE_URL="postgresql://user:password@host:5432/pulse?sslmode=require"

# AI provider: "mock" | "fallback" | "openai"
# "mock" — local deterministic responses (default, no API key)
# "fallback" — offline template-based responses
# "openai" — real OpenAI API (requires OPENAI_API_KEY)
AI_PROVIDER="mock"

# Only needed if AI_PROVIDER="openai"
# OPENAI_API_KEY="sk-..."
