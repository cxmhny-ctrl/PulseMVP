# === Local development (SQLite) ===
DATABASE_URL="file:./dev.db"

# === Production (Postgres — Neon / Supabase / Vercel Postgres) ===
# 1. Change `provider = "sqlite"` to `provider = "postgresql"` in prisma/schema.prisma
# 2. Set DATABASE_URL to your Postgres connection string:
# DATABASE_URL="postgresql://user:password@host:5432/pulse?sslmode=require"

# AI provider: "mock" | "fallback" | "openai" | "deepseek"
# "mock" — local deterministic responses (default, no API key)
# "fallback" — offline template-based responses
# "openai" — real OpenAI API (requires OPENAI_API_KEY, not yet implemented)
# "deepseek" — DeepSeek Reasoner via OpenAI-compatible API
AI_PROVIDER="mock"

# DeepSeek (only needed if AI_PROVIDER="deepseek")
# DEEPSEEK_API_KEY="sk-..."
# DEEPSEEK_MODEL="deepseek-reasoner"
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# OpenAI (only needed if AI_PROVIDER="openai")
# OPENAI_API_KEY="sk-..."
